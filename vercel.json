{
  "version": 2,
  "buildCommand": "npm install",
  "outputDirectory": "public",
  "functions": {
    "api/**/*.js": {
      "memory": 512,
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/admin",    "dest": "/admin.html" },
    { "src": "/login",    "dest": "/login.html" },
    { "src": "/queue",    "dest": "/queue.html" },
    { "src": "/",         "dest": "/index.html" }
  ]
}
